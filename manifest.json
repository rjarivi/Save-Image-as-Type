{
  "manifest_version": 3,
  "name": "Save Image As Type",
  "version": "1.0.0",
  "description": "Right-click any image to save it as PNG, JPG, or WebP. A simple, lightweight utility for image conversion.",
  "author": "Extension Master",
  "permissions": [
    "contextMenus",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save Image As Type"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "109"
}